# ========== AI 生成配置 ==========
# Claude API（推荐）
ANTHROPIC_API_KEY=your_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI（备选）
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o

# 豆包 AI（备选）
DOUBAO_API_KEY=e8b1a43d-aa55-446b-b3a9-59a30525b879
DOUBAO_MODEL=doubao-seed-1-8-251228

# 使用哪个AI: claude 或 openai 或 doubao
AI_PROVIDER=doubao

# ========== 微信公众号配置 ==========
WECHAT_APP_ID=wxeac08ac5656b64d6
WECHAT_APP_SECRET=1051e80229448f2a1eef1c65d40c97f2

# ========== 飞书自建应用配置 ==========
FEISHU_APP_ID=cli_a9460cdfd0fa5ccf
FEISHU_APP_SECRET=zHz1PNSxDpn5CI3ABf9stcnIXMrWroMt
# 飞书接收通知的群组 chat_id
FEISHU_CHAT_ID=oc_c03968e17e3f0620019a5bef26818245
# 事件订阅验证Token（本地HTTP服务模式需要）
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=your_encrypt_key

# ========== 图片服务配置（三选一） ==========
# Unsplash（免费，推荐）
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Pexels（免费）
PEXELS_API_KEY=your_pexels_api_key

# 图片来源优先级: unsplash / pexels / dalle
IMAGE_PROVIDER=unsplash

# ========== 爬虫配置 ==========
# 微博Cookie（登录后从浏览器开发者工具获取）
WEIBO_COOKIE=your_weibo_cookie_here

# 抖音Cookie（登录后从浏览器开发者工具获取）
DOUYIN_COOKIE=your_douyin_cookie_here

# ========== 运行配置 ==========
# 定时执行 Cron 表达式（每12小时）
CRON_SCHEDULE=0 */12 * * *

# 每次处理热点数量
TOPICS_PER_RUN=3

# 本地HTTP服务端口（飞书回调用）
LOCAL_SERVER_PORT=8080

# 日志级别: error / warn / info / debug
LOG_LEVEL=info
