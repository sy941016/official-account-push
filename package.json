{
  "name": "official-account-push",
  "version": "1.0.0",
  "description": "热点内容自动化发布系统：爬取微博/抖音热点 → AI生成文章 → 推送公众号 → 飞书通知",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "node src/main.js",
    "once": "node src/main.js --mode=once",
    "scheduler": "node src/main.js --mode=scheduler",
    "websocket": "node src/main.js --mode=websocket",
    "server": "node src/main.js --mode=server",
    "weibo-only": "node src/main.js --mode=once --source=weibo",
    "douyin-only": "node src/main.js --mode=once --source=douyin",
    "dev": "node --watch src/main.js --mode=once"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "axios": "^1.7.0",
    "cheerio": "1.0.0-rc.12",
    "dotenv": "^16.4.0",
    "form-data": "^4.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.47.0",
    "winston": "3.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "resolutions": {
    "@dabh/diagnostics": "2.0.2"
  }
}
